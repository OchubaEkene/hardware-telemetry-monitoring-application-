# DO NOT COMMIT with real passwords. Create the secret with:
#
#   kubectl create secret generic grafana-secret \
#     --from-literal=admin-password='YOUR_SECURE_PASSWORD' \
#     --namespace hardware-monitor
#
# Or apply this manifest after replacing the placeholder value.
# Encode your password:  echo -n 'your-password' | base64

apiVersion: v1
kind: Secret
metadata:
  name: grafana-secret
  namespace: hardware-monitor
type: Opaque
data:
  admin-password: Y2hhbmdlbWU=   # base64("changeme") — REPLACE THIS
