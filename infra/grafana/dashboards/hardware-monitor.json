{
  "title": "Hardware Monitor",
  "uid": "hardware-monitor",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "GPU Temperature",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "hardware_gpu_temp_celsius{instance=\"home-pc\"}",
          "legendFormat": "GPU Temp"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "unit": "celsius"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "CPU Temperature",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "hardware_cpu_temp_celsius{instance=\"home-pc\"}",
          "legendFormat": "CPU Temp"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Fan Speed",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "hardware_fan_rpm{instance=\"home-pc\"}",
          "legendFormat": "Fan RPM"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rotrpm",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Power Draw",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "hardware_power_draw_watts{instance=\"home-pc\"}",
          "legendFormat": "Power Draw"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "fixed", "fixedColor": "yellow" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "orange", "value": 150 },
              { "color": "red", "value": 200 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Temperature History",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "hardware_gpu_temp_celsius{instance=\"home-pc\"}",
          "legendFormat": "GPU Temp (°C)"
        },
        {
          "expr": "hardware_cpu_temp_celsius{instance=\"home-pc\"}",
          "legendFormat": "CPU Temp (°C)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Fan & Power History",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "hardware_fan_rpm{instance=\"home-pc\"}",
          "legendFormat": "Fan (RPM)"
        },
        {
          "expr": "hardware_power_draw_watts{instance=\"home-pc\"}",
          "legendFormat": "Power (W)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Fan (RPM)" },
            "properties": [{ "id": "unit", "value": "rotrpm" }]
          },
          {
            "matcher": { "id": "byName", "options": "Power (W)" },
            "properties": [{ "id": "unit", "value": "watt" }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ]
}
